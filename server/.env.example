# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (dev)
DATABASE_URL="file:./dev.db"

# PostgreSQL (prod)
# DATABASE_URL="postgresql://user:password@localhost:5432/cooking_with_her"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production
JWT_SECRET="cooking-with-her-dev-secret-change-in-prod"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Groq AI ──────────────────────────────────────────────────────────────────
# Obtenha sua chave gratuita em: https://console.groq.com
# Free tier: ~14.400 requisições/dia com llama-3.3-70b-versatile
GROQ_API_KEY=
PRISMA_DB=