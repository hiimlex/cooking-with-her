# ── Docker (local server) ────────────────────────────────────────────────────
# Port exposed on the host machine (default: 80)
APP_PORT=80

# PostgreSQL password for the local Docker database
DB_PASSWORD=cwh_local_secret

# Secret used to sign JWT tokens — change this!
JWT_SECRET=cooking-with-her-change-me-in-prod

# Set to "true" on first run to populate the database with sample data
SEED_DB=false

# ── Render (backend) — set manually in the Render dashboard
# Prisma Postgres — get both strings from console.prisma.io → Connect
# DATABASE_URL=postgres://<token>@pooled.db.prisma.io:5432/postgres?sslmode=require
# DIRECT_URL=postgres://<token>@db.prisma.io:5432/postgres?sslmode=require
#   └─ same as DATABASE_URL but replace "pooled.db.prisma.io" with "db.prisma.io"
# JWT_SECRET → auto-generated by Render (generateValue: true in render.yaml)
# CORS_ORIGIN=https://<user>.github.io

# ── GitHub Pages (frontend) — set as repo Actions secrets/variables ──────────
# Base path matching your GH Pages URL: /<repo-name>/ or / (custom domain)
# VITE_BASE_PATH=/cooking-with-her/
# Full URL of the Render API service
# VITE_API_URL=https://cooking-with-her-api.onrender.com
